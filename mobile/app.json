{
  "expo": {
    "name": "Thrift Scout",
    "slug": "thrift-scout",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.thriftscout.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Thrift Scout needs camera access to scan items.",
        "NSPhotoLibraryUsageDescription": "Thrift Scout needs photo library access to pick item photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.thriftscout.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "platforms": ["ios", "android"]
  }
}
